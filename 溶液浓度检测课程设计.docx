<w:tc><w:p><w:r><w:t>单价</w:t></w:r></w:p></w:tc>
</w:tr>
<w:tr>
<w:tc><w:p><w:r><w:t>LED光源</w:t></w:r></w:p></w:tc>
<w:tc><w:p><w:r><w:t>650nm, 5mW</w:t></w:r></w:p></w:tc>
<w:tc><w:p><w:r><w:t>1</w:t></w:r></w:p></w:tc>
