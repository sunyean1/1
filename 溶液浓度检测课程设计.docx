<w:tc><w:p><w:r><w:t>占比</w:t></w:r></w:p></w:tc>
<w:tc><w:p><w:r><w:t>评分标准</w:t></w:r></w:p></w:tc>
</w:tr>
<w:tr>
<w:tc><w:p><w:r><w:t>设计方案</w:t></w:r></w:p></w:tc>
<w:tc><w:p><w:r><w:t>20%</w:t></w:r></w:p></w:tc>
<w:tc><w:p><w:r><w:t>原理清晰，方案合理可行</w:t></w:r></w:p></w:tc>
</w:tr>
<w:tr>
