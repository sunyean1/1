</w:tr>
<w:p><w:r><w:t>七、设计报告要求</w:t></w:r></w:p>
<w:p><w:r><w:t>7.1 报告结构</w:t></w:r></w:p>
<w:p><w:r><w:t>1. 摘要（200-300字）</w:t></w:r></w:p>
<w:p><w:r><w:t>2. 绪论</w:t></w:r></w:p>
<w:p><w:r><w:t>3. 系统设计</w:t></w:r></w:p>
<w:p><w:r><w:t>4. 实验方法与步骤</w:t></w:r></w:p>
<w:p><w:r><w:t>5. 结果与分析</w:t></w:r></w:p>
<w:p><w:r><w:t>6. 误差分析</w:t></w:r></w:p>
<w:p><w:r><w:t>7. 结论</w:t></w:r></w:p>
<w:p><w:r><w:t>8. 参考文献（不少于15篇）</w:t></w:r></w:p>
<w:p><w:r><w:t>7.2 评分标准（满分100分）</w:t></w:r></w:p>
<w:tbl>
<w:tblPr><w:tblW w:w="5000" w:type="auto"/></w:tblPr>
<w:tr>
