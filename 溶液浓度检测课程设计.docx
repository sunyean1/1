<w:tc><w:p><w:r><w:t>电路设计正确，调试成功</w:t></w:r></w:p></w:tc>
</w:tr>
<w:tr>
<w:tc><w:p><w:r><w:t>软件程序</w:t></w:r></w:p></w:tc>
<w:tc><w:p><w:r><w:t>20%</w:t></w:r></w:p></w:tc>
<w:tc><w:p><w:r><w:t>代码结构清晰，算法正确</w:t></w:r></w:p></w:tc>
</w:tr>
<w:tr>
<w:tc><w:p><w:r><w:t>实验数据</w:t></w:r></w:p></w:tc>
